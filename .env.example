# Database (SQLite for local dev, PostgreSQL for production)
DATABASE_URL=sqlite:///./delivery_intelligence.db
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/delivery_intelligence

# OpenAI (optional — improves AI assistant & classification)
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini

# Cursor agent (daily Issue Intelligence 5 PM IST + weekly CEO brief — Cursor subscription)
# Create key: https://cursor.com/dashboard → Integrations
CURSOR_API_KEY=
CURSOR_MODEL=composer-2.5
CURSOR_ANALYSIS_ENABLED=true
# ISSUE_INTELLIGENCE_DAILY_ENABLED=true
# ISSUE_INTELLIGENCE_DAILY_HOUR_IST=17

# ── Asana (read-only) ──────────────────────────────────────────────────────
# Get token: https://app.asana.com/0/my-apps → Create token
ASANA_ACCESS_TOKEN=
# Workspace GID: GET https://app.asana.com/api/1.0/workspaces (use the "gid" field)
ASANA_WORKSPACE_GID=
# Custom field name for support category (your field is "Type")
ASANA_TYPE_FIELD_NAME=Type

# ── Jira (read-only, separate project) ─────────────────────────────────────
# Base URL: https://YOUR-ORG.atlassian.net
JIRA_BASE_URL=https://your-org.atlassian.net
# Your Atlassian account email
JIRA_EMAIL=
# API token: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=ATATT3xFfGF0GXsafCKSta9vpp-2f0jff13FnQi8Np66SI-kELcDCoEekwfAJ2of2NTWF56tgE0-8__bExarPUBQrW1nEkCbI6P8rwWegAjV_0wzyG3U2yC5Jh_WUP__UndKPokZhZHlCKwy7i2kjUICeah8YTcEnBteinuhUBHPXCuE2D97E_U=F333F6DF
# Jira project key (e.g. DEL, PROJ) — issues pulled from this project
JIRA_PROJECT_KEY=AXP

# App
USE_MOCK_DATA=true
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
API_PREFIX=/api/v1

# ── Google Sheets (service account) ─────────────────────────────────────────
# Download JSON key from Google Cloud → IAM → Service Accounts → Keys
# Share each spreadsheet with the service account client_email as Editor
GOOGLE_SERVICE_ACCOUNT_FILE=secrets/google-service-account.json
