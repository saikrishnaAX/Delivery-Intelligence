# Database (SQLite for local dev, PostgreSQL for production)
DATABASE_URL=sqlite:///./delivery_intelligence.db
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/delivery_intelligence

# OpenAI (optional — improves AI assistant & classification)
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini

# Cursor agent (daily Issue Intelligence 5 PM IST + weekly CEO brief — Cursor subscription)
# Create key: https://cursor.com/dashboard → Integrations
CURSOR_API_KEY=
CURSOR_MODEL=composer-2.5
CURSOR_ANALYSIS_ENABLED=true
# ISSUE_INTELLIGENCE_DAILY_ENABLED=true
# ISSUE_INTELLIGENCE_DAILY_HOUR_IST=17

# ── Asana (read-only) ──────────────────────────────────────────────────────
# Get token: https://app.asana.com/0/my-apps → Create token
ASANA_ACCESS_TOKEN=
# Workspace GID: GET https://app.asana.com/api/1.0/workspaces (use the "gid" field)
ASANA_WORKSPACE_GID=
# Custom field name for support category (your field is "Type")
ASANA_TYPE_FIELD_NAME=Type

# ── Jira (read-only, separate project) ─────────────────────────────────────
# Base URL: https://YOUR-ORG.atlassian.net
JIRA_BASE_URL=https://your-org.atlassian.net
# Your Atlassian account email
JIRA_EMAIL=
# API token: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your-jira-api-token
# Jira project key (e.g. DEL, PROJ) — issues pulled from this project
JIRA_PROJECT_KEY=AXP

# App
USE_MOCK_DATA=true
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
API_PREFIX=/api/v1

# Auto-sync (backend loop). Minimum enforced is 5 minutes.
AUTO_SYNC_ENABLED=true
AUTO_SYNC_INTERVAL_MINUTES=10

# Near-real-time Asana + Jira updates. Requires a public HTTPS URL (Cloudflare Tunnel).
# Example: https://your-subdomain.trycloudflare.com
# App registers:
#   POST {url}/api/v1/webhooks/asana
#   POST {url}/api/v1/webhooks/jira
ASANA_WEBHOOK_TARGET_URL=

# ── Google Sheets (service account) ─────────────────────────────────────────
# Download JSON key from Google Cloud → IAM → Service Accounts → Keys
# Share each spreadsheet with the service account client_email as Editor
GOOGLE_SERVICE_ACCOUNT_FILE=secrets/google-service-account.json

# ── Status-move alerts (Sprint Planning → tech team Google Chat only) ───────
# Create the webhook INSIDE the Chat space where tech should see updates:
#   that space → Apps & integrations → Manage webhooks → Add webhook
# The app posts only to whatever space owns this URL (one space = one webhook).
GOOGLE_CHAT_WEBHOOK_URL=
# Email is OFF unless you list tech addresses here (no fallback to SUPPORT_HEAD).
STATUS_MOVE_EMAIL_TO=
STATUS_MOVE_NOTIFY_ENABLED=true
# true = only Testing / Done / Released moves (quieter Chat)
STATUS_MOVE_HIGHLIGHT_ONLY=false
# New Jira Sub-task under a parent requirement → same Bugs Chat space
JIRA_BUG_NOTIFY_ENABLED=true

# ── Gmail SMTP (release notes, workshop reminders; status email only if set above)
# GMAIL_USER=you@autorox.co
# GMAIL_APP_PASSWORD=your-app-password
# SUPPORT_HEAD_EMAIL=
